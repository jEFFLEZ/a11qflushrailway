# --- TOKENS & SÉCURITÉ ---
# Token admin/API partagé pour /run, /api/admin/run, mémoire protégée
QFLUSH_TOKEN=sk_admin_7fA92KxLmQ4zP8rT1bVnC3eY
# (optionnel, alternative legacy)
NPZ_ADMIN_TOKEN=sk_admin_7fA92KxLmQ4zP8rT1bVnC3eY

# --- FLOWS ---
# Flow principal utilisé pour le chat
QFLUSH_CHAT_FLOW=a11.chat.v1
# Liste des flows publics autorisés (séparés par virgule)
QFLUSH_PUBLIC_FLOWS=a11.chat.v1

# --- REDIS (optionnel) ---
#REDIS_URL=redis://127.0.0.1:6379
QFLUSH_DISABLE_REDIS=1
QFLUSH_ENABLE_REDIS=0

# --- MÉMOIRE ÉPHÉMÈRE ---
QFLUSH_EPHEMERAL_MEMORY_TTL_SEC=3600
QFLUSH_EPHEMERAL_MEMORY_MAX_TTL_SEC=86400
QFLUSH_EPHEMERAL_MEMORY_NAMESPACE=a11
QFLUSH_EPHEMERAL_MEMORY_SCOPE=shared
QFLUSH_EPHEMERAL_MEMORY_PREFIX=qflush:ephemeral

# --- PORT ---
QFLUSHD_PORT=43421

